ModernTextList < TextList
  border-width: 1
  border-color: #343434
  background-color: #141416
  padding: 4

ModernHorizontalSeparator < UIWidget
  height: 1
  background-color: #2f3135
  phantom: true
  focusable: false

ModernProgressBar < UIProgressBar
  height: 6
  background-color: #3f6b4c
  border-width: 1
  border-color: #2a2c30
  font: verdana-11px-rounded
  text-offset: 0 0

  $!on:
    visible: false
    margin-top: 0
    margin-bottom: 0
    height: 0

ModernTabBarVertical < UITabBar
  width: 118

  ModernScrollablePanel
    id: buttonsPanel
    anchors.top: parent.top
    anchors.left: parent.left
    anchors.right: scrollBar.left
    anchors.bottom: parent.bottom
    vertical-scrollbar: scrollBar
    margin-right: 6
    padding: 8

  ModernVerticalScrollBar
    id: scrollBar
    anchors.top: parent.top
    anchors.bottom: parent.bottom
    anchors.right: parent.right
    step: 16
    pixels-scroll: true

    $!on:
      width: 0

ModernTabBarVerticalButton < UIButton
  height: 40
  color: #9b9b9b
  anchors.left: parent.left
  anchors.right: parent.right
  text-align: left
  text-offset: 34 0
  icon-align: left
  icon-offset: 8 0
  background-color: #17181b
  border-width: 1
  border-color: #2f3135

  $first:
    anchors.top: parent.top

  $!first:
    anchors.top: prev.bottom
    margin-top: 6

  $hover !checked:
    color: #f0f0f0
    background-color: #202124
    border-color: #4a4a4a

  $disabled:
    color: #686868
    icon-color: #686868

  $checked:
    color: #f0f0f0
    background-color: #252525
    border-color: #5a5a5a

  $on !checked:
    color: #8db59a

