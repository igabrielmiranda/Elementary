    anchors.left: parent.left
    anchors.right: parent.right
    height: 9
    image-source:
    image-border: 0
    background-color: #17181b

    $hover:
      background-color: #202124

    $pressed:
      background-color: #252525

  ModernScrollBarSlider
  ModernScrollBarValueLabel

ModernHorizontalScrollBar < UIScrollBar
  orientation: horizontal
  height: 10
  width: 40
  image-source:
  image-border: 0
  background-color: #111214
  border-width: 1
  border-color: #2f3135

  UIButton
    id: decrementButton
