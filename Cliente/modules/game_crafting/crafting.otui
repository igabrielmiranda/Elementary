        anchors.top: dismantlePreview.bottom
        anchors.left: parent.left
        anchors.right: parent.right
        margin-top: 12
        margin-left: 12
        margin-right: 12
        height: 20
        text-align: center
        text-wrap: true
        text-auto-resize: false
        color: #d8d8d8
        text: Nenhum equipamento selecionado.

      Label
