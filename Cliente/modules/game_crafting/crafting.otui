      id: count6
      anchors.right: prev.left
      text-align: right
      margin-right: 5

    Label
      id: qualityResult
      anchors.top: craftOutcome.bottom
      anchors.horizontalCenter: craftOutcome.horizontalCenter
      margin-top: 12
      width: 170
      text-align: center
      text-wrap: true
      text-auto-resize: true
      color: #d8d8d8
      visible: false

    Label
      id: qualityStatus
      anchors.top: qualityResult.bottom
      anchors.horizontalCenter: qualityResult.horizontalCenter
      margin-top: 8
      width: 190
      text-align: center
      text-wrap: true
      text-auto-resize: true
      color: #afafaf
      visible: false

    Label
      anchors.bottom: parent.bottom
      anchors.right: parent.right
      margin-right: 5
      margin-bottom: 49
      text: Total Cost
      text-align: right
      color: #afafaf

    RefinedDarkCard
      anchors.bottom: parent.bottom
      anchors.right: parent.right
      margin-right: 5
      margin-bottom: 35
      size: 95 14

      UIItem
        anchors.top: parent.top
        anchors.left: parent.left
        margin-top: -10
        margin-left: -10
        size: 34 34
        padding: 1
        item-id: 3031
        virtual: true
      
      Label
        id: totalCost
        anchors.top: parent.top
        anchors.left: parent.left
        anchors.right: parent.right
        margin-right: 4
        text-align: right

    Label
      anchors.bottom: parent.bottom
      anchors.right: parent.right
      margin-right: 5
      margin-bottom: 19
      text: Backpack Money
      text-align: right
      color: #afafaf

    RefinedDarkCard
      anchors.bottom: parent.bottom
      anchors.right: parent.right
      margin-right: 5
      margin-bottom: 5
      size: 95 14

      UIItem
        anchors.top: parent.top
        anchors.left: parent.left
        margin-top: -10
        margin-left: -10
        size: 34 34
        padding: 1
        item-id: 3031
        virtual: true
      
      Label
        id: playerMoney
        anchors.top: parent.top
        anchors.left: parent.left
        anchors.right: parent.right
        margin-right: 4
        text-align: right

    CategoryButton
      id: craftButton
      anchors.bottom: parent.bottom
      anchors.horizontalCenter: parent.horizontalCenter
      size: 80 34
      margin-bottom: 5
      @onClick: modules.game_crafting.craftItem()

      CategoryItem
        item-id: 3460
      
      CategoryLabel
        text: Craft

  MaterialRefiningPanel
    id: refinePanel
    anchors.top: categoriesSeparator.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    anchors.bottom: separator.top
    margin-top: 10
    margin-bottom: 10
    visible: false

  CraftMiniPanel
    id: dismantlePanel
    anchors.top: itemsList.top
    anchors.left: parent.left
    anchors.right: parent.right
    anchors.bottom: separator.top
    margin-bottom: 10
    text: Desmontar Equipamento
    visible: false

    Label
      id: dismantleHelp
      anchors.top: parent.top
      anchors.left: parent.left
      anchors.right: parent.right
      margin-top: 4
      text: Arraste um item craftado para o slot de desmontagem.
      text-align: center
      color: #afafaf

    Panel
      id: dismantleSourceArea
      anchors.top: dismantleHelp.bottom
      anchors.left: parent.left
      margin-top: 12
      margin-left: 14
      width: 220
      height: 122

      Label
        anchors.top: parent.top
        anchors.left: parent.left
        anchors.right: parent.right
        margin-top: 4
        text: Equipamento
        text-align: center
        color: #cfcfcf

      CraftMaterialSlot
        id: dismantleInputSlot
        anchors.top: prev.bottom
        anchors.horizontalCenter: parent.horizontalCenter
        margin-top: 10
        size: 46 46

      Label
        id: dismantleInputLabel
        anchors.top: dismantleInputSlot.bottom
        anchors.left: parent.left
        anchors.right: parent.right
        margin-top: 8
        margin-left: 18
        margin-right: 18
        height: 20
        text: Slot de desmontagem
        text-align: center
        text-wrap: true
        text-auto-resize: false
        color: #cfcfcf

      RefinedDarkButton
        id: dismantleClearButton
        anchors.top: dismantleInputLabel.bottom
        anchors.horizontalCenter: parent.horizontalCenter
        margin-top: 8
        width: 100
        text: Limpar
        @onClick: modules.game_crafting.clearDismantleSelectionByUser()

    CraftVerticalDivider
      id: dismantleDivider
      anchors.top: dismantleHelp.bottom
      anchors.left: dismantleSourceArea.right
      anchors.bottom: dismantleSourceArea.bottom
      margin-top: 8
      margin-left: 12

    Panel
      id: dismantleResultArea
      anchors.top: dismantleHelp.bottom
      anchors.left: dismantleDivider.right
      anchors.right: parent.right
      margin-top: 8
      margin-left: 16
      margin-right: 14
      height: 122

      Label
        anchors.top: parent.top
        anchors.left: parent.left
        anchors.right: parent.right
        margin-top: 4
        text: Preview
        text-align: center
        color: #cfcfcf

      CraftPreviewItem
