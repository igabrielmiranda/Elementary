CraftMiniPanel < RefinedDarkTitledPanel
  text-offset: 0 2
  text-align: top
  padding-left: 4
  padding-bottom: 3
  padding-top: 18
  padding-right: 2

CraftTitledList < RefinedDarkScrollablePanel
  text-offset: 0 2
  text-align: top
  color: #f0f0f0
  font: verdana-11px-rounded
  padding-bottom: 6
  padding-top: 20
  padding-right: 12
  padding-left: 4

CategoryButton < RefinedDarkButton
  size: 106 34
  padding-left: 0
  text-align: left
  color: #f0f0f0

  $on:
    background-color: #1d2024
    border-color: #596472

CraftVerticalDivider < UIWidget
  width: 1
  background-color: #333333
  phantom: true
  focusable: false

CategoryItem < UIItem
  anchors.top: parent.top
  anchors.left: parent.left
  size: 34 34
  padding: 1
  virtual: true
  phantom: true

CategoryLabel < Label
  anchors.top: parent.top
  anchors.left: prev.right
  anchors.right: parent.right
  anchors.bottom: parent.bottom
  text-align: left
  color: #d8d8d8

ItemListItem < RefinedDarkListEntry
  phantom: false
  width: 188
  height: 38
  padding-left: 3
  focusable: true
  @onClick: modules.game_crafting.selectItem(self:getId())

  UIItem
    id: item
    anchors.verticalCenter: parent.verticalCenter
    anchors.left: parent.left
    size: 34 34
    padding: 1
    virtual: true
    phantom: true
  
  Label
    id: name
    anchors.top: item.top
    anchors.left: item.right
    anchors.right: parent.right
    margin-top: 3
    margin-left: 5
    text-align: left
    color: #f0f0f0
    phantom: true
  
  Label
    id: level
    anchors.left: item.right
    anchors.right: parent.right
    anchors.bottom: item.bottom
    margin-bottom: 3
    margin-left: 5
    text-align: left
    color: #9b9b9b
    phantom: true

CountLabel < Label
  anchors.top: prev.top
  anchors.bottom: prev.bottom
  font: verdana-11px-rounded
  text-auto-resize: true
  margin-top: 5
  color: #d8d8d8

CraftPreviewItem < UIItem
  size: 34 34
  padding: 1
  virtual: true
  phantom: true

  UIWidget
    id: rarityId
    anchors.fill: parent
    image-source: /images/ui/rarity_frames
    phantom: true
    visible: false

CraftMaterialSlot < RefinedDarkCard
  size: 34 34
  background-color: #111214
  border-color: #3a3a3a
  focusable: false
  padding: 0

  CraftPreviewItem
    id: item
    anchors.centerIn: parent

DismantleMaterialRow < RefinedDarkPanel
  height: 28
  background-color: #161719

RefinedDarkMainWindow
  text: Crafting System
  size: 640 620

  Panel
    id: categories
    anchors.top: parent.top
    anchors.horizontalCenter: parent.horizontalCenter
    width: 580
    height: 102
    layout:
      type: grid
      cell-size: 115 34
      flow: true
    grid-columns: 3
    grid-rows: 3

    CategoryButton
      id: herbalistCat
      width: 108
      @onClick: modules.game_crafting.selectCategory("herbalist")
      grid.column: 0
      grid.row: 0

      CategoryItem
        item-id: 25423

      CategoryLabel
        text: Herbalist

    CategoryButton
      id: woodcuttingCat
      width: 111
      @onClick: modules.game_crafting.selectCategory("woodcutting")
      grid.column: 1
      grid.row: 0

      CategoryItem
        item-id: 23946

      CategoryLabel
        text: Woodcutting

    CategoryButton
      id: miningCat
      width: 98
      @onClick: modules.game_crafting.selectCategory("mining")
      grid.column: 2
      grid.row: 0

      CategoryItem
        item-id: 23775

      CategoryLabel
        text: Mining
    
    CategoryButton
      id: generalcraftingCat
      width: 98
      @onClick: modules.game_crafting.selectCategory("generalcrafting")
      grid.column: 2
      grid.row: 0

      CategoryItem
        item-id: 20312

      CategoryLabel
        text: Crafting
    
    CategoryButton
      id: armorsmithCat
      width: 98
      @onClick: modules.game_crafting.selectCategory("armorsmith")
      grid.column: 2
      grid.row: 0

      CategoryItem
        item-id: 25456

      CategoryLabel
        text: Armorsmith

    CategoryButton
      id: weaponsmithCat
      width: 98
      @onClick: modules.game_crafting.selectCategory("weaponsmith")
      grid.column: 2
      grid.row: 0

      CategoryItem
        item-id: 25446

      CategoryLabel
        text: Weaponsmith
    
    CategoryButton
      id: jewelsmithCat
      width: 98
      @onClick: modules.game_crafting.selectCategory("jewelsmith")
      grid.column: 2
      grid.row: 0

      CategoryItem
        item-id: 25470

      CategoryLabel
        text: Jewelsmith

    CategoryButton
      id: refineCat
      width: 98
      @onClick: modules.game_crafting.openRefine()
      grid.column: 2
      grid.row: 0

      CategoryItem
        item-id: 26401

      CategoryLabel
        text: Refine

    CategoryButton
      id: dismantleCat
      width: 108
      @onClick: modules.game_crafting.selectCategory("dismantle")
      grid.column: 0
      grid.row: 2

      CategoryItem
        item-id: 2189

      CategoryLabel
        text: Desmontar

  RefinedDarkSeparator
    id: categoriesSeparator
    anchors.top: prev.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    margin-top: 10

  Panel
    id: searchPanel
    anchors.top: prev.top
    anchors.left: parent.left
    anchors.right: parent.right
    margin-top: 10
    height: 23
    background-color: #161719
    border-width: 1
    border-color: #333333
    padding-left: 6
    padding-right: 6

    Label
      anchors.verticalCenter: parent.verticalCenter
      anchors.left: parent.left
      text: Search
      color: #d8d8d8

    ModernInput
      id: searchInput
      anchors.verticalCenter: parent.verticalCenter
      anchors.left: prev.right
      margin-left: 5
      width: 130
      @onKeyPress: modules.game_crafting.onSearch()
  
  RefinedDarkSeparator
    id: searchSeparator
    anchors.top: prev.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    margin-top: 10

  CraftTitledList
    id: itemsList
    anchors.top: prev.bottom
    anchors.left: parent.left
    anchors.bottom: separator.top
    margin-top: 10
    margin-bottom: 10
    width: 210
    text: Craftable Items
    vertical-scrollbar: itemsListScrollbar
    layout: verticalBox
    auto-focus: none

  RefinedDarkVerticalScrollBar
    id: itemsListScrollbar
    anchors.top: itemsList.top
    anchors.bottom: itemsList.bottom
    anchors.right: itemsList.right
    margin-top: 18
    margin-bottom: 4
    margin-right: 3
    step: 24
    pixels-scroll: true

  CraftVerticalDivider
    id: listDivider
    anchors.top: itemsList.top
    anchors.bottom: itemsList.bottom
    anchors.left: itemsList.right
    margin-left: 10
  
  CraftMiniPanel
    id: craftPanel
    anchors.top: prev.top
    anchors.bottom: prev.bottom
    anchors.left: prev.right
    anchors.right: parent.right
    margin-left: 10
    text: Crafting Process

    CraftPreviewItem
      id: craftOutcome
      anchors.centerIn: parent
      margin-bottom: 10

    Panel
      id: craftLine1
      anchors.top: craftOutcome.top
      anchors.right: craftOutcome.left
