        anchors.top: dismantleSelectedName.bottom
        anchors.left: parent.left
        anchors.right: parent.right
        margin-left: 16
        margin-right: 16
        margin-top: 8
        height: 18
        text: Aviso: o item sera destruido.
        text-align: center
        text-wrap: false
        text-auto-resize: false
        color: #d8c173
        visible: false

