      anchors.top: dismantleButton.bottom
      anchors.left: parent.left
      anchors.right: parent.right
      margin-left: 16
      margin-right: 16
      margin-top: 2
      height: 16
      text-align: center
      text-wrap: false
      text-auto-resize: false
      color: #afafaf
      visible: false

  RefinedDarkSeparator
    id: separator
    anchors.bottom: parent.bottom
    anchors.left: parent.left
    anchors.right: parent.right
    margin-bottom: 30

  RefinedDarkButton
    anchors.bottom: parent.bottom
    anchors.right: parent.right
    text: Fechar
    width: 76
    @onClick: modules.game_crafting.hide()
